@page "/student/diem-danh-hoat-dong/{IDHoatDong}"
@model HoatDongSinhVien.Pages.Student.DiemDanhHoatDongModel
@{
    ViewData["Title"] = "Điểm Danh Hoạt Động";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">
                📌 @ViewData["Title"]
            </h4>
        </div>

        <div class="card-body">
            @if (Model.ThoiGianDong.HasValue)
            {
                <div class="alert alert-warning text-center shadow-sm mb-4">
                    <h5 class="mb-0 fw-bold">
                        ⏱️ Thời gian điểm danh còn lại: <span id="countdown-timer" class="text-danger">Đang tính...</span>
                    </h5>
                </div>

                <script>
                    // Lấy mốc thời gian đóng từ C# truyền xuống (đổi ra chuẩn ISO)
                    var endTime = new Date('@Model.ThoiGianDong.Value.ToString("yyyy-MM-ddTHH:mm:ss")').getTime();

                    // Cập nhật đồng hồ mỗi 1 giây
                    var x = setInterval(function() {
                        var now = new Date().getTime();
                        var distance = endTime - now;

                        // Tính toán số phút và giây
                        var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                        var seconds = Math.floor((distance % (1000 * 60)) / 1000);

                        // Hiển thị ra màn hình
                        document.getElementById("countdown-timer").innerHTML = minutes + " phút " + seconds + " giây ";

                        // Hết giờ sẽ chuyển về trang xem hoạt động
                        if (distance <= 0) {
                            clearInterval(x);
                            document.getElementById("countdown-timer").innerHTML = "ĐÃ HẾT GIỜ!";
                            // Trình duyệt tự động đá văng về trang XemHoatDong
                            window.location.href = "/xem-hoat-dong/@Model.IDHoatDong";
                        }
                    }, 1000);
                </script>
            }
            @* Thông báo *@
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    @TempData["Error"]
                </div>
            }

            @if (TempData["ErrorDiemDanh"] != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-x-circle-fill"></i>
                    @TempData["ErrorDiemDanh"]
                </div>
            }

            @if (TempData["SuccessDiemDanh"] != null)
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle-fill"></i>
                    @TempData["SuccessDiemDanh"]
                </div>
            }

            <form enctype="multipart/form-data" method="post">
                <div class="mb-3">
                    <label for="AnhThe" class="form-label fw-semibold">
                        Ảnh thẻ sinh viên
                    </label>

                    <input type="file"
                           class="form-control"
                           id="AnhThe"
                           name="AnhThe"
                           accept="image/*"
                           required />

                    <div class="form-text">
                        Chỉ chấp nhận ảnh (.jpg, .png). Nên dùng ảnh rõ nét .
                    </div>
                </div>

                <input type="hidden" name="IDHoatDong" value="@Model.IDHoatDong" />

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-camera-fill"></i> Điểm danh
                    </button>

                    <a asp-page="/Student/XemHoatDong" asp-route-IDHoatDong="@Model.IDHoatDong"
                       class="btn btn-outline-secondary">
                        ⬅ Quay lại
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>


